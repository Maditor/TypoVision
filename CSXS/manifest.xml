<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0"
    ExtensionBundleId="com.typovision.maditor"
    ExtensionBundleVersion="1.0.0"
    ExtensionBundleName="TypoVision"
    xmlns:ns="http://ns.adobe.com/cep">

  <ExtensionList>
    <Extension Id="com.typovision.panel" Version="1.0.0" />
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- PHXS = Photoshop. 19.0 = Photoshop CC 2018. 99.9 cover tất cả bản tương lai -->
      <Host Name="PHXS" Version="[19.0,99.9]" />
      <Host Name="PHSP" Version="[19.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.typovision.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
          <CEFCommandLine>
            <!-- Cho phép panel dùng Node.js (fs, os, http...) ngay trong context HTML -->
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>TypoVision</Menu>
          <Icons>
            <Icon Type="Normal">./icons/icon.png</Icon>
            <Icon Type="RollOver">./icons/icon.png</Icon>
            <Icon Type="DarkNormal">./icons/icon.png</Icon>
            <Icon Type="DarkRollOver">./icons/icon.png</Icon>
          </Icons>
          <Geometry>
            <Size>
              <Height>480</Height>
              <Width>200</Width>
            </Size>
            <MinSize>
              <Height>460</Height>
              <Width>200</Width>
            </MinSize>
            <MaxSize>
              <Height>460</Height>
              <Width>2000</Width>
            </MaxSize>
          </Geometry>
          <Icons>
            <Icon Type="Normal">./icons/icon.png</Icon>
            <Icon Type="RollOver">./icons/icon.png</Icon>
            <Icon Type="DarkNormal">./icons/icon.png</Icon>
            <Icon Type="DarkRollOver">./icons/icon.png</Icon>
          </Icons>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
